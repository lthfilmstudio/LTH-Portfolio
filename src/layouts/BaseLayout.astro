---
import '../styles/tokens.css';
import '../styles/base.css';
import '../styles/thumb.css';
import '../styles/nav.css';
import '../styles/hero.css';
import '../styles/sections.css';
import '../styles/footer.css';
import '../styles/responsive.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = '林姿嫺 Tzushien Lin — Feature Film & Series Editor',
  description = '林姿嫺 Tzushien Lin — 電影／劇集剪輯指導。兩度金鐘獎最佳剪輯得主。A two-time Golden Bell Award winner for Best Editing.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Inter:wght@300;400;500;600&family=Noto+Serif+TC:wght@300;400;500&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <slot />
</body>
</html>
