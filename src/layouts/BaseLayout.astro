---
import '../styles/tokens.css';
import '../styles/base.css';
import '../styles/thumb.css';
import '../styles/nav.css';
import '../styles/hero.css';
import '../styles/sections.css';
import '../styles/portfolio.css';
import '../styles/work-detail.css';
import '../styles/footer.css';
import '../styles/responsive.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  schemaJsonLd?: object;
  keywords?: string;
  noindex?: boolean;
}

const {
  title = '林姿嫺 Tzushien Lin — 剪輯指導 Film & Series Editor｜兩度金鐘獎最佳剪輯',
  description = '林姿嫺 Tzushien Lin，電影／劇集剪輯指導，兩度榮獲金鐘獎戲劇類最佳剪輯獎（《茶金》、《牽紙鷂的手》），並以《有生之年》入圍。代表作品包括《我們與惡的距離 II》、《拜六禮拜》、《那張照片裡的我們》、《人浮於愛》、《夏日最後的祕密》等。原本那間剪輯工作室 LTH Film Studio 創辦人。',
  ogImage = '/og.png',
  ogImageAlt = '林姿嫺 Tzushien Lin — 剪輯指導 Film & Series Editor',
  schemaJsonLd,
  keywords = '林姿嫺,Tzushien Lin,剪輯指導,剪輯師,金鐘獎,最佳剪輯,茶金,牽紙鷂的手,有生之年,我們與惡的距離,拜六禮拜,那張照片裡的我們,人浮於愛,原本那間剪輯工作室,LTH Film Studio,台灣剪輯師,電影剪輯,劇集剪輯,Taiwan Film Editor,Drama Series Editor,Golden Bell Awards',
  noindex = false,
} = Astro.props;

// OG image MIME type 從副檔名推斷
const ogImageType = ogImage.endsWith('.png') ? 'image/png'
  : (ogImage.endsWith('.jpg') || ogImage.endsWith('.jpeg')) ? 'image/jpeg'
  : ogImage.endsWith('.webp') ? 'image/webp'
  : 'image/jpeg';

// 部署在 *.pages.dev 預覽 URL 時，canonical 指回主網域並標 noindex 避免重複內容
const isPreviewHost = Astro.url.hostname.endsWith('.pages.dev');
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const absOgImage = new URL(ogImage, Astro.site).toString();
---
<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content={keywords} />
  <meta name="author" content="林姿嫺 Tzushien Lin" />
  <link rel="canonical" href={canonicalUrl} />
  {(isPreviewHost || noindex) && <meta name="robots" content="noindex, nofollow" />}
  <meta name="format-detection" content="telephone=no" />

  <!-- Favicon -->
  <link rel="icon" href="/favicon.ico" sizes="48x48" />
  <link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <meta name="theme-color" content="#0a0908" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={absOgImage} />
  <meta property="og:image:type" content={ogImageType} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={ogImageAlt} />
  <meta property="og:site_name" content="林姿嫺 Tzushien Lin" />
  <meta property="og:locale" content="zh_TW" />
  <meta property="og:locale:alternate" content="en_US" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={absOgImage} />
  <meta name="twitter:image:alt" content={ogImageAlt} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Inter:wght@300;400;500;600&family=Noto+Serif+TC:wght@300;400;500&display=swap"
    rel="stylesheet"
  />

  {schemaJsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(schemaJsonLd)} />
  )}
</head>
<body>
  <slot />
  <script>
    // 手機版專屬：滑到 viewport 中央 20% 區帶時，海報套上 .is-in-view（取代 hover）
    // 桌面有滑鼠用 :hover；手機沒滑鼠改靠 IntersectionObserver 偵測中央位置
    if (window.matchMedia('(max-width: 960px)').matches && 'IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            e.target.classList.toggle('is-in-view', e.isIntersecting);
          });
        },
        { rootMargin: '-40% 0px -40% 0px', threshold: 0 },
      );
      const watch = () => {
        document
          .querySelectorAll<HTMLElement>('.featured-item, .work-card')
          .forEach((el) => observer.observe(el));
      };
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', watch);
      } else {
        watch();
      }
    }
  </script>
</body>
</html>
