---
import type { Work } from '../data/works';
import { CATEGORY_LABELS, firstExternalLink } from '../data/works';

interface Props {
  work: Work;
}
const { work } = Astro.props;
const href = work.hasDetail ? `/works/${work.slug}/` : firstExternalLink(work);
const external = !work.hasDetail;

// 沒有 cover 時 fallback 到 15 個 gradient placeholder
const thumbNum =
  (work.slug.split('').reduce((a, c) => a + c.charCodeAt(0), 0) % 15) + 1;
const dataShort = work.titleZh.slice(0, 4);

const categoryLabels = work.categories.map((c) => CATEGORY_LABELS[c]);
---
<a
  class="work-card"
  href={href ?? '#'}
  data-categories={work.categories.join(' ')}
  {...(external ? { target: '_blank', rel: 'noopener' } : {})}
>
  {work.cover ? (
    <div class="work-cover work-cover--image">
      <img src={work.cover} alt={`${work.titleZh} ${work.titleEn}`.trim()} loading="lazy" />
    </div>
  ) : (
    <div class={`work-cover thumb th-${thumbNum}`} data-short={dataShort}></div>
  )}
  <div class="work-meta">
    <div class="work-cats">
      {categoryLabels.map((c, i) => (
        <span class="work-cat">
          {c.zh} <span class="en">{c.en}</span>
          {i < categoryLabels.length - 1 && <span class="sep"> · </span>}
        </span>
      ))}
    </div>
    <div class="work-title-zh">{work.titleZh}</div>
    {work.titleEn && <div class="work-title-en">{work.titleEn}</div>}
    <div class="work-sub">
      {work.director && <span class="work-director">{work.director}</span>}
      {work.year && <span class="work-year">{work.year}</span>}
    </div>
  </div>
</a>
