---
import awardsData from '../../data/awards.json';
import worksData from '../../data/works.json';
const awards = awardsData;
const worksOptions = (worksData as any[]).map((w) => ({
  slug: w.slug,
  titleZh: w.titleZh,
  titleEn: w.titleEn || '',
  cover: w.cover || '',
}));
---
<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>LTH Portfolio Admin · 得獎入圍</title>
    <style is:global>
      :root {
        --bg: #0a0908;
        --surface: #141311;
        --surface-2: #1a1816;
        --line: #2a2824;
        --line-soft: #1f1d1a;
        --text: #ece9e1;
        --text-dim: #a9a399;
        --text-faint: #6a655c;
        --accent: #c9a961;
        --accent-dim: #8a7a4a;
        --danger: #d66a54;
        --ok: #6fb07f;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: -apple-system, "Noto Sans TC", sans-serif;
        font-size: 14px;
        line-height: 1.5;
      }
      header.admin-header {
        padding: 1.2rem 2rem;
        border-bottom: 1px solid var(--line);
        display: flex;
        align-items: center;
        gap: 2rem;
        position: sticky;
        top: 0;
        background: rgba(10, 9, 8, 0.92);
        backdrop-filter: blur(12px);
        z-index: 10;
      }
      header.admin-header h1 {
        font-size: 1rem;
        margin: 0;
        letter-spacing: 0.1em;
        font-weight: 500;
      }
      header.admin-header nav { display: flex; gap: 1rem; flex: 1; }
      header.admin-header nav a {
        color: var(--text-dim);
        text-decoration: none;
        padding: 0.4rem 0.8rem;
        border-radius: 2px;
        font-size: 0.78rem;
        letter-spacing: 0.08em;
      }
      header.admin-header nav a.active {
        color: var(--accent);
        border: 1px solid var(--accent-dim);
      }
      header.admin-header .meta { color: var(--text-faint); font-size: 0.75rem; letter-spacing: 0.1em; }
      main { padding: 2rem; max-width: 1200px; margin: 0 auto; }

      .toolbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
      }
      .toolbar h2 {
        margin: 0;
        font-size: 0.9rem;
        letter-spacing: 0.1em;
        color: var(--text-dim);
      }
      .btn {
        background: transparent;
        border: 1px solid var(--line);
        color: var(--text-dim);
        padding: 0.5rem 1rem;
        font-size: 0.78rem;
        letter-spacing: 0.1em;
        cursor: pointer;
        border-radius: 2px;
        transition: all 0.2s;
      }
      .btn:hover { border-color: var(--accent); color: var(--accent); }
      .btn.primary { border-color: var(--accent); color: var(--accent); }
      .btn.primary:hover { background: var(--accent); color: var(--bg); }
      .btn.danger:hover { border-color: var(--danger); color: var(--danger); }
      .btn:disabled { opacity: 0.4; cursor: not-allowed; }

      .award-list { display: flex; flex-direction: column; gap: 1rem; }

      .award-card {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 3px;
        padding: 1.2rem;
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
      }

      .preview-box {
        position: relative;
        width: 380px;          /* 1:1 對齊前台實際尺寸（典型桌面 viewport） */
        max-width: 100%;
        /* 不固定 aspect-ratio：讓 preview-content 文字撐出高度，跟前台 hero-award-item 邏輯一致 */
        background: var(--surface-2);
        border: 1px solid var(--line-soft);
        overflow: hidden;
        border-radius: 2px;
      }
      .preview-bg {
        position: absolute;
        inset: 0;
        opacity: 0.45;
        filter: grayscale(0.3);
        transition: opacity 0.2s, filter 0.2s;
      }
      /* 「前台實際樣子」 — 切換成訪客看到的低透明度狀態 */
      .preview-box.is-realistic .preview-bg {
        opacity: 0.12;
        filter: grayscale(0.4) blur(0.5px);
      }
      .preview-box .realistic-toggle {
        position: absolute;
        top: 0.4rem;
        right: 0.4rem;
        background: rgba(0, 0, 0, 0.65);
        color: var(--text-dim);
        border: 1px solid var(--line);
        padding: 0.2rem 0.55rem;
        font-size: 0.62rem;
        letter-spacing: 0.08em;
        cursor: pointer;
        z-index: 3;
        border-radius: 2px;
      }
      .preview-box .realistic-toggle:hover { color: var(--accent); border-color: var(--accent); }
      .preview-box.is-realistic .realistic-toggle { color: var(--accent); border-color: var(--accent); }
      .preview-bg img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        user-select: none;
        -webkit-user-drag: none;
      }
      .preview-box.is-clickable { cursor: pointer; transition: outline 0.2s; }
      .preview-box.is-clickable:hover { outline: 1px solid var(--accent); outline-offset: 2px; }
      .preview-box .click-hint {
        position: absolute;
        left: 50%;
        top: 50%;
        transform: translate(-50%, -50%);
        background: rgba(0, 0, 0, 0.78);
        color: var(--text);
        padding: 0.4rem 0.9rem;
        font-size: 0.72rem;
        letter-spacing: 0.18em;
        pointer-events: none;
        z-index: 4;
        opacity: 0;
        transition: opacity 0.2s;
        border-radius: 2px;
      }
      .preview-box.is-clickable:hover .click-hint { opacity: 1; }

      /* ===== Modal ===== */
      .cover-modal-backdrop {
        position: fixed; inset: 0;
        background: rgba(0, 0, 0, 0.78);
        z-index: 100;
        display: none;
        align-items: center;
        justify-content: center;
      }
      .cover-modal-backdrop[data-open="true"] { display: flex; }
      .cover-modal {
        background: var(--surface);
        border: 1px solid var(--line);
        padding: 1.5rem;
        max-width: 92vw;
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }
      .cover-modal-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
      }
      .cover-modal-head h3 {
        margin: 0;
        font-size: 0.85rem;
        letter-spacing: 0.12em;
        color: var(--text-dim);
        font-weight: 500;
      }
      .cover-modal-head button.close-x {
        background: transparent;
        border: none;
        color: var(--text-faint);
        font-size: 1.4rem;
        cursor: pointer;
        line-height: 1;
        padding: 0 0.3rem;
      }
      .cover-modal-head button.close-x:hover { color: var(--accent); }
      /* 大尺寸編輯框 — 比實際前台放大 2 倍方便操作，仍維持比例 */
      .cover-modal .editor-box {
        position: relative;
        width: 760px;
        max-width: calc(92vw - 4rem);
        background: var(--surface-2);
        border: 1px solid var(--line);
        overflow: hidden;
      }
      .cover-modal .editor-bg { position: absolute; inset: 0; opacity: 0.5; filter: grayscale(0.2); }
      .cover-modal .editor-bg img {
        width: 100%; height: 100%; object-fit: cover;
        cursor: grab;
        user-select: none;
        -webkit-user-drag: none;
        touch-action: none;
      }
      .cover-modal .editor-bg img.is-dragging { cursor: grabbing; }
      .cover-modal .editor-content {
        position: relative;
        z-index: 1;
        padding: 1.7rem 2.4rem; /* 等比放大版前台 padding */
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        pointer-events: none; /* 不擋拖曳 */
      }
      .cover-modal .editor-content .meta-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.4rem; }
      .cover-modal .editor-content .meta-row > span:first-child { color: var(--accent); font-size: 1.44rem; letter-spacing: 0.3em; text-transform: uppercase; }
      .cover-modal .editor-content .meta-row > span:last-child { font-family: 'Cormorant Garamond', serif; font-size: 1.9rem; color: var(--text-dim); }
      .cover-modal .editor-content .work { font-family: 'Noto Serif TC', serif; font-size: 1.96rem; color: var(--text); letter-spacing: 0.05em; margin-bottom: 0.2rem; line-height: 1.3; }
      .cover-modal .editor-content .work .en { font-family: 'Cormorant Garamond', serif; font-size: 1.72rem; color: var(--text); margin-left: 0.4em; font-style: italic; font-weight: 300; }
      .cover-modal .editor-content .award-line { font-size: 1.64rem; color: var(--text); font-family: 'Noto Serif TC', serif; letter-spacing: 0.08em; line-height: 1.4; margin-top: 0.4rem; }
      .cover-modal .editor-content .award-line .en { color: var(--text-dim); font-family: 'Cormorant Garamond', serif; font-size: 1.56rem; margin-left: 0.4em; font-style: italic; }
      .cover-modal .editor-hint {
        position: absolute;
        right: 0.6rem;
        bottom: 0.5rem;
        background: rgba(0, 0, 0, 0.7);
        color: var(--text-dim);
        padding: 0.2rem 0.6rem;
        font-size: 0.65rem;
        letter-spacing: 0.1em;
        pointer-events: none;
        z-index: 5;
      }
      .cover-modal .editor-foot {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        font-size: 0.78rem;
        color: var(--text-dim);
      }
      .cover-modal .editor-foot .readout { font-variant-numeric: tabular-nums; }
      .cover-modal .editor-foot .spacer { flex: 1; }
      /* 跟前台 hero-award-item 完全同步：padding、字體、行距 */
      .preview-content {
        position: relative;
        z-index: 1;
        padding: 0.85rem 1.2rem;
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
      }
      .preview-content .meta-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.4rem;
      }
      .preview-content .meta-row > span:first-child {
        color: var(--accent);
        font-size: 0.72rem;
        letter-spacing: 0.3em;
        text-transform: uppercase;
      }
      .preview-content .meta-row > span:last-child {
        font-family: 'Cormorant Garamond', serif;
        font-size: 0.95rem;
        color: var(--text-dim);
      }
      .preview-content .meta-row.nom > span:first-child { color: var(--accent); }
      .preview-content .work {
        font-family: 'Noto Serif TC', serif;
        font-size: 0.98rem;
        color: var(--text);
        letter-spacing: 0.05em;
        margin-bottom: 0.2rem;
        line-height: 1.3;
      }
      .preview-content .work .en {
        font-family: 'Cormorant Garamond', serif;
        font-size: 0.86rem;
        color: var(--text);
        margin-left: 0.4em;
        font-style: italic;
        font-weight: 300;
      }
      .preview-content .award-line {
        font-size: 0.82rem;
        color: var(--text);
        font-family: 'Noto Serif TC', serif;
        letter-spacing: 0.08em;
        line-height: 1.4;
        margin-top: 0.4rem;
      }
      .preview-content .award-line .en {
        color: var(--text-dim);
        font-family: 'Cormorant Garamond', serif;
        font-size: 0.78rem;
        margin-left: 0.4em;
        font-style: italic;
      }

      .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.8rem 1.2rem;
      }
      .form-row { display: flex; flex-direction: column; gap: 0.3rem; }
      .form-row.full { grid-column: 1 / -1; }
      .form-row label {
        font-size: 0.7rem;
        letter-spacing: 0.1em;
        color: var(--text-faint);
        text-transform: uppercase;
      }
      .form-row input,
      .form-row select {
        background: var(--surface-2);
        border: 1px solid var(--line);
        color: var(--text);
        padding: 0.5rem 0.7rem;
        border-radius: 2px;
        font-size: 0.85rem;
        font-family: inherit;
      }
      .form-row input:focus,
      .form-row select:focus {
        outline: none;
        border-color: var(--accent);
      }

      .slider-row { display: grid; grid-template-columns: auto 1fr 60px; gap: 0.7rem; align-items: center; font-size: 0.75rem; color: var(--text-dim); }
      .slider-row input[type="range"] { padding: 0; }
      .slider-row .val { text-align: right; color: var(--text); font-variant-numeric: tabular-nums; }

      .card-actions {
        margin-top: 0.8rem;
        display: flex;
        gap: 0.6rem;
        justify-content: flex-end;
      }

      .toast {
        position: fixed;
        top: 4.5rem;
        left: 50%;
        transform: translateX(-50%);
        background: var(--surface);
        border: 1px solid var(--line);
        border-left: 3px solid var(--accent);
        padding: 0.9rem 1.2rem;
        border-radius: 3px;
        font-size: 0.85rem;
        max-width: 360px;
        z-index: 200;
        display: none;
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4);
      }
      .toast[data-open="true"] { display: block; }
      .toast.ok { border-left-color: var(--ok); }
      .toast.err { border-left-color: var(--danger); }
      .toast a { color: var(--accent); }

      .save-bar {
        position: sticky;
        bottom: 0;
        background: rgba(10, 9, 8, 0.92);
        backdrop-filter: blur(12px);
        padding: 1rem 0;
        border-top: 1px solid var(--line);
        margin-top: 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .save-bar .status { color: var(--text-faint); font-size: 0.78rem; }
      .save-bar .status.dirty { color: var(--accent); }
    </style>
  </head>
  <body>
    <header class="admin-header">
      <h1>LTH Portfolio · Admin</h1>
      <nav style="display: flex; gap: 1rem; flex: 1; margin-left: 2rem; align-items: center;">
        <a href="/admin/" style="color: var(--text-faint); font-size: 0.72rem; letter-spacing: 0.08em; text-decoration: none;">← 後台首頁</a>
        <a href="/admin/works/" style="color: var(--text-dim); padding: 0.4rem 0.8rem; border-radius: 2px; font-size: 0.78rem; letter-spacing: 0.08em; text-decoration: none;">作品資訊</a>
        <a href="/admin/awards/" style="color: var(--accent); border: 1px solid var(--accent); padding: 0.4rem 0.8rem; border-radius: 2px; font-size: 0.78rem; letter-spacing: 0.08em; text-decoration: none;">得獎入圍</a>
        <a href="/admin/selected/" style="color: var(--text-dim); padding: 0.4rem 0.8rem; border-radius: 2px; font-size: 0.78rem; letter-spacing: 0.08em; text-decoration: none;">精選作品</a>
        <a href="/cdn-cgi/access/logout" style="margin-left: auto; color: var(--text-faint); padding: 0.4rem 0.8rem; border-radius: 2px; font-size: 0.72rem; letter-spacing: 0.08em; text-decoration: none; border: 1px solid var(--line);" title="登出 CF Access">登出</a>
      </nav>
      <span class="meta" id="count">{awards.length} entries</span>
    </header>

    <main>
      <div class="toolbar">
        <h2>得獎入圍紀錄</h2>
        <button class="btn primary" id="add-btn" type="button">＋ 新增一筆</button>
      </div>

      <div class="award-list" id="award-list"></div>

      <div class="save-bar">
        <span class="status" id="dirty-status">無變更</span>
        <button class="btn primary" id="save-btn" type="button" disabled>儲存並發布</button>
      </div>
    </main>

    <div class="toast" id="toast"></div>

    <!-- 海報位置編輯彈窗 -->
    <div class="cover-modal-backdrop" id="cover-modal" role="dialog" aria-modal="true">
      <div class="cover-modal">
        <div class="cover-modal-head">
          <h3 id="cover-modal-title">調整海報位置</h3>
          <button type="button" class="close-x" id="cover-modal-close" aria-label="關閉">✕</button>
        </div>
        <div class="editor-box" id="cover-editor-box">
          <div class="editor-bg">
            <img id="cover-editor-img" draggable="false" src="" alt="" />
          </div>
          <div class="editor-content" id="cover-editor-content"></div>
          <div class="editor-hint">拖曳改位置 · 滾輪縮放</div>
        </div>
        <div class="editor-foot">
          <span class="readout" id="cover-editor-readout">X 50% · Y 50% · 100%</span>
          <span class="spacer"></span>
          <button type="button" class="btn" id="cover-editor-reset">還原預設</button>
          <button type="button" class="btn" id="cover-editor-cancel">取消</button>
          <button type="button" class="btn primary" id="cover-editor-done">完成</button>
        </div>
      </div>
    </div>

    <script define:vars={{ initialAwards: awards, worksOptions }}>
      let awards = JSON.parse(JSON.stringify(initialAwards));
      let dirty = false;

      // slug → cover 查表，後台預覽用
      const worksCoverBySlug = new Map(worksOptions.map((w) => [w.slug, w.cover]));
      function resolvePoster(a) {
        if (a.workSlug && worksCoverBySlug.has(a.workSlug)) {
          return worksCoverBySlug.get(a.workSlug) || a.poster || '';
        }
        return a.poster || '';
      }

      const list = document.getElementById('award-list');
      const dirtyStatus = document.getElementById('dirty-status');
      const saveBtn = document.getElementById('save-btn');
      const addBtn = document.getElementById('add-btn');
      const toast = document.getElementById('toast');

      function setDirty(v) {
        dirty = v;
        if (v) {
          dirtyStatus.textContent = '有未儲存變更';
          dirtyStatus.classList.add('dirty');
          saveBtn.disabled = false;
        } else {
          dirtyStatus.textContent = '無變更';
          dirtyStatus.classList.remove('dirty');
          saveBtn.disabled = true;
        }
      }

      function render() {
        list.innerHTML = '';
        // 預先生成作品下拉選項 HTML（slug 排序：有海報的優先）
        const optionsHtml = ['<option value="">— 不連結作品（用下方 poster 路徑）—</option>']
          .concat(
            worksOptions.map(
              (w) => `<option value="${escapeAttr(w.slug)}">${escape(w.titleZh)}${w.titleEn ? ' · ' + escape(w.titleEn) : ''}</option>`,
            ),
          )
          .join('');
        awards.forEach((a, i) => {
          const card = document.createElement('div');
          card.className = 'award-card';
          const effectivePoster = resolvePoster(a);
          card.innerHTML = `
            <div>
              <div class="preview-box is-clickable" data-action="open-cover" data-i="${i}">
                <button type="button" class="realistic-toggle" data-action="toggle-realistic" data-i="${i}">前台實際樣子</button>
                <div class="preview-bg">
                  <img class="poster-img" data-i="${i}" draggable="false" src="${escapeAttr(effectivePoster)}" style="object-position: ${a.posterX}% ${a.posterY}%; transform: scale(${a.posterScale / 100});" alt="" />
                </div>
                <div class="preview-content">
                  <div class="meta-row ${a.status}">
                    <span>● ${escape(a.statusZh)} · ${escape(a.statusEn)}</span>
                    <span>${escape(a.year)}</span>
                  </div>
                  <div class="work">${escape(a.workZh)}<span class="en">${escape(a.workEn)}</span></div>
                  <div class="award-line">${escape(a.awardZh)} <span class="en">${escape(a.awardEn)}</span></div>
                </div>
                <div class="click-hint">點擊調整海報位置</div>
              </div>
              <div style="margin-top: 0.5rem; display: flex; gap: 0.5rem; align-items: center; font-size: 0.7rem; color: var(--text-dim);">
                <span class="poster-readout" data-i="${i}">X ${a.posterX}% · Y ${a.posterY}% · ${a.posterScale}%</span>
                <button type="button" class="btn" data-action="reset-poster" data-i="${i}" style="padding: 0.15rem 0.5rem; font-size: 0.62rem; margin-left: auto;">還原</button>
              </div>
            </div>
            <div>
              <div class="form-grid">
                <div class="form-row">
                  <label>狀態</label>
                  <select data-field="status" data-i="${i}">
                    <option value="win" ${a.status === 'win' ? 'selected' : ''}>獲獎 Winner</option>
                    <option value="nom" ${a.status === 'nom' ? 'selected' : ''}>入圍 Nominee</option>
                  </select>
                </div>
                <div class="form-row">
                  <label>年份</label>
                  <input type="text" data-field="year" data-i="${i}" value="${escapeAttr(a.year)}" />
                </div>
                <div class="form-row">
                  <label>作品（中）</label>
                  <input type="text" data-field="workZh" data-i="${i}" value="${escapeAttr(a.workZh)}" />
                </div>
                <div class="form-row">
                  <label>作品（英）</label>
                  <input type="text" data-field="workEn" data-i="${i}" value="${escapeAttr(a.workEn)}" />
                </div>
                <div class="form-row">
                  <label>獎項（中）</label>
                  <input type="text" data-field="awardZh" data-i="${i}" value="${escapeAttr(a.awardZh)}" />
                </div>
                <div class="form-row">
                  <label>獎項（英）</label>
                  <input type="text" data-field="awardEn" data-i="${i}" value="${escapeAttr(a.awardEn)}" />
                </div>
                <div class="form-row full">
                  <label>連結作品（自動取海報）</label>
                  <select data-field="workSlug" data-i="${i}">${optionsHtml.replace(`value="${escapeAttr(a.workSlug || '')}"`, `value="${escapeAttr(a.workSlug || '')}" selected`)}</select>
                  <small style="color: var(--text-faint); font-size: 0.7rem;">${a.workSlug ? '海報來自 /admin/works／' + escape(a.workSlug) : '未連結 — 走下方手動 poster 路徑'}</small>
                </div>
                <div class="form-row full">
                  <label>海報路徑（手動覆蓋；連結作品時可留空）</label>
                  <input type="text" data-field="poster" data-i="${i}" value="${escapeAttr(a.poster || '')}" placeholder="/stills/covers/..." />
                </div>
                <div class="form-row full">
                  <label>ID（不建議改，會影響穩定性）</label>
                  <input type="text" data-field="id" data-i="${i}" value="${escapeAttr(a.id)}" />
                </div>
              </div>
              <div class="card-actions">
                <button class="btn" data-action="up" data-i="${i}" type="button" ${i === 0 ? 'disabled' : ''}>↑ 上移</button>
                <button class="btn" data-action="down" data-i="${i}" type="button" ${i === awards.length - 1 ? 'disabled' : ''}>↓ 下移</button>
                <button class="btn danger" data-action="delete" data-i="${i}" type="button">刪除</button>
              </div>
            </div>
          `;
          list.appendChild(card);
        });

        list.querySelectorAll('input, select').forEach((el) => {
          el.addEventListener('input', (e) => {
            const t = e.target;
            const i = parseInt(t.dataset.i);
            const field = t.dataset.field;
            let v = t.value;
            if (field === 'status') {
              awards[i].statusZh = v === 'win' ? '獲獎' : '入圍';
              awards[i].statusEn = v === 'win' ? 'Winner' : 'Nominee';
            }
            awards[i][field] = v;
            // workSlug 變動：更新預覽 img + 整列重繪 slug 提示
            if (field === 'workSlug' || field === 'poster') {
              const card = list.querySelectorAll('.award-card')[i];
              const img = card.querySelector('.preview-bg img');
              if (img) img.src = resolvePoster(awards[i]);
              const hint = card.querySelector('select[data-field="workSlug"]')?.parentElement.querySelector('small');
              if (hint) {
                hint.textContent = awards[i].workSlug
                  ? '海報來自 /admin/works／' + awards[i].workSlug
                  : '未連結 — 走下方手動 poster 路徑';
              }
            }
            updatePreviewText(i);
            setDirty(true);
          });
        });

        // 點擊預覽框 → 開啟編輯彈窗
        list.querySelectorAll('.preview-box.is-clickable').forEach((box) => {
          box.addEventListener('click', (e) => {
            // 排除 toggle / button 等內部元素
            if (e.target.closest('button')) return;
            const i = parseInt(box.dataset.i);
            openCoverEditor(i);
          });
        });

        list.querySelectorAll('button[data-action]').forEach((btn) => {
          btn.addEventListener('click', () => {
            const action = btn.dataset.action;
            const i = parseInt(btn.dataset.i);
            if (action === 'delete') {
              if (!confirm('確定刪除這筆得獎紀錄？')) return;
              awards.splice(i, 1);
              setDirty(true);
              render();
            } else if (action === 'up' && i > 0) {
              [awards[i - 1], awards[i]] = [awards[i], awards[i - 1]];
              setDirty(true);
              render();
            } else if (action === 'down' && i < awards.length - 1) {
              [awards[i], awards[i + 1]] = [awards[i + 1], awards[i]];
              setDirty(true);
              render();
            } else if (action === 'reset-poster') {
              awards[i].posterX = 50;
              awards[i].posterY = 50;
              awards[i].posterScale = 100;
              setDirty(true);
              render();
            } else if (action === 'toggle-realistic') {
              const card = list.querySelectorAll('.award-card')[i];
              const box = card?.querySelector('.preview-box');
              if (box) box.classList.toggle('is-realistic');
            }
          });
        });
      }

      function updatePreviewText(i) {
        const card = list.querySelectorAll('.award-card')[i];
        const a = awards[i];
        const meta = card.querySelector('.meta-row');
        if (meta) {
          meta.className = `meta-row ${a.status}`;
          meta.innerHTML = `<span>● ${escape(a.statusZh)} · ${escape(a.statusEn)}</span><span>${escape(a.year)}</span>`;
        }
        const work = card.querySelector('.work');
        if (work) work.innerHTML = `${escape(a.workZh)}<span class="en">${escape(a.workEn)}</span>`;
        const line = card.querySelector('.award-line');
        if (line) line.innerHTML = `${escape(a.awardZh)} <span class="en">${escape(a.awardEn)}</span>`;
        const img = card.querySelector('.preview-bg img');
        if (img) img.src = resolvePoster(a);
      }

      addBtn.addEventListener('click', () => {
        awards.push({
          id: 'new-' + Date.now(),
          workSlug: '',
          status: 'win',
          statusZh: '獲獎',
          statusEn: 'Winner',
          year: new Date().getFullYear().toString(),
          workZh: '',
          workEn: '',
          awardZh: '',
          awardEn: '',
          poster: '',
          posterX: 50,
          posterY: 50,
          posterScale: 100,
        });
        setDirty(true);
        render();
        window.scrollTo(0, document.body.scrollHeight);
      });

      saveBtn.addEventListener('click', async () => {
        saveBtn.disabled = true;
        saveBtn.textContent = '儲存中...';
        try {
          const res = await fetch('/admin/api/awards', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ awards }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || 'save failed');
          showToast(
            `✅ 已儲存 ${data.count} 筆<br/><small>CF Pages 約 1-2 分鐘後更新</small><br/>` +
              (data.url ? `<a href="${data.url}" target="_blank">查看 commit</a>` : ''),
            'ok',
            8000,
          );
          setDirty(false);
        } catch (err) {
          showToast(`❌ 儲存失敗：${err.message}`, 'err', 8000);
          setDirty(true);
        } finally {
          saveBtn.disabled = false;
          saveBtn.textContent = '儲存並發布';
        }
      });

      function showToast(msg, kind = 'ok', ms = 5000) {
        toast.className = `toast ${kind}`;
        toast.innerHTML = msg;
        toast.setAttribute('data-open', 'true');
        setTimeout(() => toast.setAttribute('data-open', 'false'), ms);
      }

      function escape(s) {
        return String(s ?? '').replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' })[c]);
      }
      function escapeAttr(s) { return escape(s); }

      window.addEventListener('beforeunload', (e) => {
        if (dirty) { e.preventDefault(); e.returnValue = ''; }
      });

      // ========================================
      // 海報位置編輯 Modal
      // ========================================
      const coverModal = document.getElementById('cover-modal');
      const coverModalTitle = document.getElementById('cover-modal-title');
      const coverModalClose = document.getElementById('cover-modal-close');
      const editorBox = document.getElementById('cover-editor-box');
      const editorImg = document.getElementById('cover-editor-img');
      const editorContent = document.getElementById('cover-editor-content');
      const editorReadout = document.getElementById('cover-editor-readout');
      const editorReset = document.getElementById('cover-editor-reset');
      const editorCancel = document.getElementById('cover-editor-cancel');
      const editorDone = document.getElementById('cover-editor-done');

      let editingIdx = -1;
      let editingSnapshot = null; // 取消時還原

      function clamp(n, min, max) { return Math.max(min, Math.min(max, n)); }

      function applyEditorState() {
        if (editingIdx < 0) return;
        const a = awards[editingIdx];
        editorImg.style.objectPosition = `${a.posterX}% ${a.posterY}%`;
        editorImg.style.transform = `scale(${a.posterScale / 100})`;
        editorReadout.textContent = `X ${a.posterX}% · Y ${a.posterY}% · ${a.posterScale}%`;
      }

      function openCoverEditor(i) {
        editingIdx = i;
        const a = awards[i];
        editingSnapshot = { posterX: a.posterX, posterY: a.posterY, posterScale: a.posterScale };
        coverModalTitle.textContent = `${a.workZh}（${a.workEn}） — 調整海報位置`;
        editorImg.src = resolvePoster(a);
        editorContent.innerHTML = `
          <div class="meta-row ${a.status}">
            <span>● ${escape(a.statusZh)} · ${escape(a.statusEn)}</span>
            <span>${escape(a.year)}</span>
          </div>
          <div class="work">${escape(a.workZh)}<span class="en">${escape(a.workEn)}</span></div>
          <div class="award-line">${escape(a.awardZh)} <span class="en">${escape(a.awardEn)}</span></div>
        `;
        applyEditorState();
        coverModal.setAttribute('data-open', 'true');
      }

      function closeCoverEditor(commit) {
        if (!commit && editingSnapshot && editingIdx >= 0) {
          // 取消 → 還原
          awards[editingIdx].posterX = editingSnapshot.posterX;
          awards[editingIdx].posterY = editingSnapshot.posterY;
          awards[editingIdx].posterScale = editingSnapshot.posterScale;
          render();
        } else if (commit && editingIdx >= 0) {
          // 套用 → 同步到 list 預覽
          updatePreviewText(editingIdx);
          const card = list.querySelectorAll('.award-card')[editingIdx];
          const img = card?.querySelector('.preview-bg img');
          const a = awards[editingIdx];
          if (img) {
            img.style.objectPosition = `${a.posterX}% ${a.posterY}%`;
            img.style.transform = `scale(${a.posterScale / 100})`;
          }
          const ro = card?.querySelector('.poster-readout');
          if (ro) ro.textContent = `X ${a.posterX}% · Y ${a.posterY}% · ${a.posterScale}%`;
        }
        editingIdx = -1;
        editingSnapshot = null;
        coverModal.setAttribute('data-open', 'false');
      }

      // editor img 拖曳
      let dragStart = null;
      editorImg.addEventListener('pointerdown', (e) => {
        if (editingIdx < 0) return;
        e.preventDefault();
        editorImg.setPointerCapture(e.pointerId);
        editorImg.classList.add('is-dragging');
        const rect = editorImg.getBoundingClientRect();
        const a = awards[editingIdx];
        dragStart = { x: e.clientX, y: e.clientY, cx: a.posterX, cy: a.posterY, w: rect.width, h: rect.height };
      });
      editorImg.addEventListener('pointermove', (e) => {
        if (!dragStart) return;
        const dx = e.clientX - dragStart.x;
        const dy = e.clientY - dragStart.y;
        awards[editingIdx].posterX = Math.round(clamp(dragStart.cx - (dx / dragStart.w) * 100, 0, 100));
        awards[editingIdx].posterY = Math.round(clamp(dragStart.cy - (dy / dragStart.h) * 100, 0, 100));
        applyEditorState();
        setDirty(true);
      });
      const editorEndDrag = (e) => {
        if (!dragStart) return;
        editorImg.releasePointerCapture(e.pointerId);
        editorImg.classList.remove('is-dragging');
        dragStart = null;
      };
      editorImg.addEventListener('pointerup', editorEndDrag);
      editorImg.addEventListener('pointercancel', editorEndDrag);
      editorImg.addEventListener('wheel', (e) => {
        if (editingIdx < 0) return;
        e.preventDefault();
        const delta = e.deltaY > 0 ? -3 : 3;
        awards[editingIdx].posterScale = clamp(awards[editingIdx].posterScale + delta, 50, 250);
        applyEditorState();
        setDirty(true);
      }, { passive: false });

      editorReset.addEventListener('click', () => {
        if (editingIdx < 0) return;
        awards[editingIdx].posterX = 50;
        awards[editingIdx].posterY = 50;
        awards[editingIdx].posterScale = 100;
        applyEditorState();
        setDirty(true);
      });
      editorCancel.addEventListener('click', () => closeCoverEditor(false));
      editorDone.addEventListener('click', () => closeCoverEditor(true));
      coverModalClose.addEventListener('click', () => closeCoverEditor(false));
      coverModal.addEventListener('click', (e) => {
        if (e.target === coverModal) closeCoverEditor(false);
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && coverModal.getAttribute('data-open') === 'true') {
          closeCoverEditor(false);
        }
      });

      render();
      setDirty(false);
    </script>
  </body>
</html>
