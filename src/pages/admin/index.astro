---
import works from '../../data/works.json';
import awards from '../../data/awards.json';
import selected from '../../data/selected.json';
import profile from '../../data/profile.json';

const worksCount = (works as unknown[]).length;
const awardsCount = (awards as unknown[]).length;
const selectedCount = (selected as unknown[]).length;
const langsCount = (profile.languages as unknown[]).length;

type AdminLink = {
  href: string;
  zh: string;
  en: string;
  desc: string;
  count?: string;
  ready: boolean;
};

const links: AdminLink[] = [
  {
    href: '/admin/works/',
    zh: '作品資訊',
    en: 'Works',
    desc: '新增刪除作品、編輯片名/年份/分類/連結、上傳海報、拖拉排序',
    count: `${worksCount} 部作品`,
    ready: true,
  },
  {
    href: '/admin/awards/',
    zh: '得獎入圍',
    en: 'Awards',
    desc: '新增 / 編輯獲獎入圍紀錄、調整海報底圖位置',
    count: `${awardsCount} 筆紀錄`,
    ready: true,
  },
  {
    href: '/admin/selected/',
    zh: '精選作品',
    en: 'Selected Works',
    desc: '挑選首頁 hero 區的代表作清單，拖拉排序、增刪',
    count: `${selectedCount} 部`,
    ready: true,
  },
  {
    href: '/admin/profile/',
    zh: '個人簡介',
    en: 'Profile',
    desc: '首頁左欄：姓名、職稱、中英 bio 段落、Languages 列表',
    count: `${langsCount} 種語言`,
    ready: true,
  },
];
---
<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>LTH Portfolio Admin</title>
    <style>
      :root {
        --bg: #0a0908;
        --surface: #141311;
        --line: #2a2824;
        --text: #ece9e1;
        --text-dim: #a9a399;
        --text-faint: #6a655c;
        --accent: #c9a961;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: -apple-system, "Noto Sans TC", sans-serif;
        font-size: 14px;
        line-height: 1.5;
      }
      header.admin-header {
        padding: 1.2rem 2rem;
        border-bottom: 1px solid var(--line);
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      header.admin-header h1 {
        font-size: 1rem;
        margin: 0;
        letter-spacing: 0.1em;
        font-weight: 500;
      }
      header.admin-header a.back {
        color: var(--text-faint);
        font-size: 0.72rem;
        letter-spacing: 0.08em;
        text-decoration: none;
      }
      header.admin-header a.back:hover { color: var(--accent); }
      main {
        max-width: 980px;
        margin: 0 auto;
        padding: 4rem 2rem 6rem;
      }
      .hello {
        margin-bottom: 3rem;
      }
      .hello .label {
        font-size: 0.7rem;
        letter-spacing: 0.3em;
        color: var(--text-faint);
        text-transform: uppercase;
        margin-bottom: 0.8rem;
      }
      .hello h2 {
        font-family: 'Noto Serif TC', serif;
        font-size: 1.8rem;
        font-weight: 400;
        margin: 0 0 0.4rem;
        letter-spacing: 0.05em;
      }
      .hello p {
        margin: 0;
        color: var(--text-dim);
        font-size: 0.88rem;
        letter-spacing: 0.04em;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.2rem;
      }
      .card {
        display: block;
        padding: 1.6rem 1.4rem;
        border: 1px solid var(--line);
        background: var(--surface);
        text-decoration: none;
        color: var(--text);
        transition: border-color 0.25s, transform 0.25s;
        position: relative;
      }
      .card:hover {
        border-color: var(--accent);
        transform: translateY(-2px);
      }
      .card .zh {
        font-family: 'Noto Serif TC', serif;
        font-size: 1.1rem;
        font-weight: 500;
        letter-spacing: 0.08em;
        margin-bottom: 0.2rem;
      }
      .card .en {
        font-size: 0.7rem;
        letter-spacing: 0.25em;
        color: var(--accent);
        text-transform: uppercase;
        margin-bottom: 1rem;
      }
      .card .desc {
        color: var(--text-dim);
        font-size: 0.82rem;
        line-height: 1.55;
        margin-bottom: 1.2rem;
        min-height: 2.5em;
      }
      .card .meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.72rem;
        color: var(--text-faint);
        letter-spacing: 0.1em;
        padding-top: 0.8rem;
        border-top: 1px solid var(--line);
      }
      .card .meta .arrow {
        color: var(--accent);
        transition: transform 0.25s;
      }
      .card:hover .meta .arrow {
        transform: translateX(4px);
      }
      .card.coming-soon {
        opacity: 0.55;
        pointer-events: none;
      }
      .card.coming-soon .meta .arrow {
        color: var(--text-faint);
      }
    </style>
  </head>
  <body>
    <header class="admin-header">
      <h1>LTH Portfolio · Admin</h1>
      <div style="display: flex; gap: 1rem; align-items: center;">
        <a href="/" class="back">← 回到網站</a>
        <a href="/cdn-cgi/access/logout" class="back" style="border: 1px solid var(--line); padding: 0.4rem 0.8rem; border-radius: 2px;" title="登出 CF Access">登出</a>
      </div>
    </header>

    <main>
      <div class="hello">
        <div class="label">後台首頁</div>
        <h2>選擇要管理的內容</h2>
        <p>所有更動都會直接 commit 到 GitHub，部署完才會反應到正式站。</p>
      </div>

      <div class="grid">
        {links.map((l) => (
          <a class={`card${l.ready ? '' : ' coming-soon'}`} href={l.ready ? l.href : '#'}>
            <div class="zh">{l.zh}</div>
            <div class="en">{l.en}</div>
            <div class="desc">{l.desc}</div>
            <div class="meta">
              <span>{l.count ?? '即將推出'}</span>
              <span class="arrow">→</span>
            </div>
          </a>
        ))}
      </div>
    </main>
  </body>
</html>
