---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BrandMark from '../../components/BrandMark.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { works, CATEGORY_LABELS } from '../../data/works';
import type { Work, LinkType } from '../../data/works';
import { versionedUrl } from '../../data/cover-version';

export async function getStaticPaths() {
  return works
    .filter((w) => w.hasDetail)
    .map((w) => ({
      params: { slug: w.slug },
      props: { work: w },
    }));
}

interface Props { work: Work }
const { work } = Astro.props;

const LINK_LABELS: Record<LinkType, string> = {
  youtube: 'YouTube',
  facebook: 'Facebook',
  netflix: 'Netflix',
  prime: 'Prime Video',
  disney: 'Disney+',
  appletv: 'Apple TV+',
  max: 'Max',
  iqiyi: 'iQIYI',
  kktv: 'KKTV',
  linetv: 'LINE TV',
  litv: 'LiTV',
  wetv: 'WeTV',
  catchplay: 'CATCHPLAY',
  friday: 'friDay',
  myvideo: 'MyVideo',
  hakkatv: 'HakkaTV',
  pts: 'PTSPlus',
  hami: 'Hami Video',
  vimeo: 'Vimeo',
  link: 'Link',
};

const thumbNum =
  (work.slug.split('').reduce((a, c) => a + c.charCodeAt(0), 0) % 15) + 1;
const dataShort = work.titleZh.slice(0, 4);

const title = `${work.titleZh}${work.titleEn ? ' ' + work.titleEn : ''} | 林姿嫺 剪輯`;

const description = work.description
  ? work.description.replace(/\s+/g, ' ').slice(0, 158)
  : `${work.titleZh}${work.titleEn ? ' ' + work.titleEn : ''}（${work.year || ''}）— 林姿嫺 Tzushien Lin 擔任剪輯指導。${CATEGORY_LABELS[work.primaryCategory].zh}${work.director ? '，導演：' + work.director : ''}。`;

// 每作品專屬 OG 圖（用 cover），fallback 到全站 OG
const ogImage = work.cover || '/og.png';

// 作品專屬 keywords
const keywords = [
  work.titleZh,
  work.titleEn,
  '林姿嫺',
  'Tzushien Lin',
  '剪輯',
  '剪輯指導',
  CATEGORY_LABELS[work.primaryCategory].zh,
  CATEGORY_LABELS[work.primaryCategory].en,
  work.director,
  work.writers,
  '原本那間剪輯工作室',
  'LTH Film Studio',
].filter(Boolean).join(',');

// Schema.org CreativeWork
const workSchema = {
  '@context': 'https://schema.org',
  '@type':
    work.primaryCategory === 'feature'
      ? 'Movie'
      : work.primaryCategory === 'series'
        ? 'TVSeries'
        : work.primaryCategory === 'short'
          ? 'Movie'
          : work.primaryCategory === 'tvmovie'
            ? 'TVMovie'
            : 'CreativeWork',
  name: work.titleZh,
  alternateName: work.titleEn || undefined,
  datePublished: work.year || undefined,
  description: work.description || undefined,
  director: work.director ? { '@type': 'Person', name: work.director } : undefined,
  editor: { '@type': 'Person', name: '林姿嫺 Tzushien Lin' },
  author: work.writers ? { '@type': 'Person', name: work.writers } : undefined,
};
---
<BaseLayout title={title} description={description} ogImage={ogImage} keywords={keywords} schemaJsonLd={workSchema}>

<div class="bokeh-bg"></div>

<nav>
  <a class="brand" href="/">
    <BrandMark />
    <div class="brand-text">
      <span class="brand-zh">林姿嫺</span>
      <span class="brand-en">Tzushien Lin · Editor</span>
    </div>
  </a>
  <ul>
    <li><a href="/#works">Works</a></li>
    <li><a href="/#contact">Contact</a></li>
  </ul>
</nav>

<main class="work-detail">

  <a class="back-link" href="/#works">← 返回作品列表 Back to Portfolio</a>

  <header class="work-detail-header">
    <div class="work-detail-cats">
      {work.categories.map((c, i) => (
        <span class="work-cat">
          {CATEGORY_LABELS[c].zh} <span class="en">{CATEGORY_LABELS[c].en}</span>
          {i < work.categories.length - 1 && <span class="sep"> · </span>}
        </span>
      ))}
    </div>

    <h1 class="work-detail-title-zh">{work.titleZh}</h1>
    {work.titleEn && <div class="work-detail-title-en">{work.titleEn}</div>}

    <div class="work-detail-meta">
      {work.year && <span class="wd-meta-item"><span class="wd-meta-label">Year</span>{work.year}</span>}
      {work.director && <span class="wd-meta-item"><span class="wd-meta-label">導演 Director</span>{work.director}</span>}
      {work.writers && <span class="wd-meta-item"><span class="wd-meta-label">編劇 Writer</span>{work.writers}</span>}
    </div>
  </header>

  <div class="work-detail-body">
    {work.cover ? (
      <div class="work-detail-cover work-detail-cover--image">
        <img
          src={versionedUrl(work.cover)}
          alt={`${work.titleZh} ${work.titleEn}`.trim()}
          style={`object-position: ${work.coverX ?? 50}% ${work.coverY ?? 50}%; transform: scale(${(work.coverScale ?? 100) / 100});`}
        />
      </div>
    ) : (
      <div class={`work-detail-cover thumb th-${thumbNum}`} data-short={dataShort}></div>
    )}

    <div class="work-detail-content">
      {work.description && (
        <div class="wd-section">
          <h2 class="wd-section-title">作品說明 <span class="en">Project Notes</span></h2>
          <div class="wd-description">
            {work.description.split('\n').map((p) => p.trim() && <p>{p}</p>)}
          </div>
        </div>
      )}

      {(work.links?.length ?? 0) > 0 && (
        <div class="wd-section">
          <h2 class="wd-section-title">延伸資訊 <span class="en">More</span></h2>
          <ul class="wd-links">
            {work.links!.map((l) => {
              const platformName = LINK_LABELS[l.type];
              const mainLabel = l.label ?? platformName;
              const showPlatform = l.label && l.label.trim().toLowerCase() !== platformName.toLowerCase();
              return (
                <li>
                  <a href={l.url} target="_blank" rel="noopener" class={`wd-link wd-link--${l.type}`}>
                    <span class="wd-link-icon" aria-hidden="true">▶</span>
                    <span class="wd-link-content">
                      <span class="wd-link-label">{mainLabel}</span>
                      {showPlatform && <span class="wd-link-platform">{platformName}</span>}
                    </span>
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      )}
    </div>
  </div>

</main>

<SiteFooter />

</BaseLayout>
