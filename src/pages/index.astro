---
import BaseLayout from '../layouts/BaseLayout.astro';
import BrandMark from '../components/BrandMark.astro';
import WorkCard from '../components/WorkCard.astro';
import { works, CATEGORY_LABELS, CATEGORY_ORDER } from '../data/works';
import awards from '../data/awards.json';
import selectedSlugs from '../data/selected.json';

// Schema.org Person — 讓 Google 搜尋結果顯示獎項、職稱
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: '林姿嫺',
  alternateName: 'Tzushien Lin',
  jobTitle: '剪輯指導 Supervising Editor',
  description: '電影／劇集剪輯指導，兩度金鐘獎最佳剪輯得主',
  url: 'https://lthfilmstudio.com',
  sameAs: ['https://www.imdb.com/name/nm6202567/'],
  worksFor: {
    '@type': 'Organization',
    name: '原本那間剪輯工作室 LTH Film Studio',
    url: 'https://lthfilmstudio.com',
  },
  award: [
    '第 57 屆金鐘獎戲劇類剪輯獎（茶金 Gold Leaf, 2022）',
    '第 45 屆金鐘獎剪輯獎（牽紙鷂的手 The Kite Soaring, 2010）',
    '第 59 屆金鐘獎戲劇類剪輯獎入圍（有生之年 Living, 2024）',
  ],
  knowsLanguage: ['zh-TW', 'nan-TW', 'en', 'hak-TW', 'th'],
};

// Nalin 精選代表作 — 來源 src/data/selected.json，由 /admin/selected 後台維護
const selectedWorks = (selectedSlugs as string[])
  .map((s) => works.find((w) => w.slug === s))
  .filter((w): w is NonNullable<typeof w> => Boolean(w));

function thumbClass(slug: string): string {
  const n = (slug.split('').reduce((a, c) => a + c.charCodeAt(0), 0) % 15) + 1;
  return `th-${n}`;
}
---
<BaseLayout schemaJsonLd={personSchema}>

<div class="bokeh-bg"></div>

<!-- NAV -->
<nav>
  <div class="brand">
    <BrandMark />
    <div class="brand-text">
      <span class="brand-zh">林姿嫺</span>
      <span class="brand-en">Tzushien Lin · Film & Series Editor</span>
    </div>
  </div>
  <ul>
    <li><a href="#works">Works</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
</nav>

<main>

<!-- HERO -->
<section class="hero">
  <div class="hero-left">
    <div class="hero-name-row">
      <h1>林姿嫺</h1>
      <span class="en-name">Tzushien Lin</span>
    </div>

    <div class="hero-titles">
      <span class="role-zh">電影 / 劇集 剪輯指導</span>
      <span class="role-en">Film & Series Editor</span>
    </div>

    <div class="hero-profile">
      <p class="lead-zh">以《茶金》、《牽紙鷂的手》兩度榮獲金鐘獎最佳剪輯獎，並以《有生之年》入圍金鐘獎最佳剪輯獎。</p>
      <p class="lead-en">A two-time Golden Bell Award winner for Best Editing in a Drama Series, for Gold Leaf and The Kite Soaring, and a nominee for Best Editing for Living.</p>
      <p class="sub-zh">近期作品包括《那張照片裡的我們》、《我們與惡的距離 II》、《拜六禮拜》、《人浮於愛》、《夏日最後的祕密》等。現成立「原本那間剪輯工作室」。</p>
      <p class="sub-en">Recent works include The Photo from 1977, The World Between Us II: After the Flames, Holiday, Adrift in Love, and Summer Blue Hour. Founder of LTH Film Studio.</p>
    </div>
  </div>

  <aside class="hero-right">
    <div class="hero-awards-label">
      <span>Awards & Recognition</span>
    </div>

    <div class="hero-awards-row">
      {awards.map((a: any) => (
        <div class={`hero-award-item ${a.status}`}>
          <div class="award-bg" aria-hidden="true">
            <img
              src={a.poster}
              alt=""
              loading="lazy"
              style={`object-position: ${a.posterX ?? 50}% ${a.posterY ?? 50}%; transform: scale(${(a.posterScale ?? 100) / 100});`}
            />
          </div>
          <div class="award-content">
            <div class="award-meta">
              <span class="award-status-sm"><span class="dot"></span> {a.statusZh} · {a.statusEn}</span>
              <span class="award-yr">{a.year}</span>
            </div>
            <div class="award-work">{a.workZh}<span class="work-en">{a.workEn}</span></div>
            <div class="award-name-sm">
              <span class="award-name-zh">{a.awardZh}</span>
              <span class="award-name-en">{a.awardEn}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </aside>

  <div class="featured-label">
    <span>Selected Works</span>
  </div>

  <div class="featured-list">
    {selectedWorks.map((w, i) => (
      <a class="featured-item" href={w.hasDetail ? `/works/${w.slug}/` : '#'}>
        <span class="featured-num" aria-hidden="true">{i + 1}</span>
        {w.cover ? (
          <div class="featured-thumb featured-thumb--image">
            <img src={w.cover} alt={`${w.titleZh} ${w.titleEn}`.trim()} loading="lazy" />
          </div>
        ) : (
          <div class={`thumb featured-thumb ${thumbClass(w.slug)}`} data-short={w.titleZh.slice(0, 4)}></div>
        )}
        <span class="title">
          <span class="title-zh">{w.titleZh}</span>
          {w.titleEn && <span class="title-en">{w.titleEn}</span>}
        </span>
      </a>
    ))}
  </div>

  <a class="scroll-cue" href="#works" aria-label="往下看作品集">
    <span class="scroll-cue-label">作品集 Portfolio</span>
    <span class="scroll-cue-arrow" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M12 5v14M5 12l7 7 7-7" />
      </svg>
    </span>
  </a>
</section>

<!-- PORTFOLIO SECTION DIVIDER -->
<div class="section-divider" id="works">
  <span class="num">01 / Portfolio</span>
  <div class="line"></div>
  <h2>作品 <span class="en">Portfolio</span></h2>
</div>

<!-- PORTFOLIO -->
<section class="portfolio">
  <div class="filter-chips" role="tablist">
    {CATEGORY_ORDER.map((cat) => {
      const count = works.filter((w) => w.categories.includes(cat)).length;
      if (count === 0) return null;
      const isDefault = cat === 'series';
      return (
        <button
          class={`chip${isDefault ? ' active' : ''}`}
          data-filter={cat}
          type="button"
          role="tab"
          aria-selected={isDefault ? 'true' : 'false'}
        >
          {CATEGORY_LABELS[cat].zh} <span class="chip-en">{CATEGORY_LABELS[cat].en}</span>
        </button>
      );
    })}
  </div>

  <div class="works-grid" data-active-filter="series">
    {works.map((work) => (
      <WorkCard work={work} />
    ))}
  </div>
</section>

</main>

<!-- FOOTER -->
<footer id="contact">
  <div class="footer-hero">
    <div class="footer-eyebrow">Get in touch · 聯絡</div>
    <h3 class="footer-title">Let's Connect.</h3>
    <p class="footer-sub">For new projects and collaborations</p>

    <form class="contact-form" id="contact-form" novalidate>
      <div class="form-row">
        <label class="form-field">
          <span class="form-label">姓名 Name *</span>
          <input type="text" name="name" required autocomplete="name" />
        </label>
        <label class="form-field">
          <span class="form-label">公司或單位名 Company</span>
          <input type="text" name="company" autocomplete="organization" />
        </label>
      </div>
      <label class="form-field">
        <span class="form-label">信箱 Email *</span>
        <input type="email" name="email" required autocomplete="email" />
      </label>
      <label class="form-field">
        <span class="form-label">想聊什麼？ What's on your mind? *</span>
        <textarea name="message" rows="5" required placeholder="可以聊作品類型、預算、時程，或任何想問的。Project type, budget, timeline, or anything else you'd like to discuss."></textarea>
      </label>

      <button class="form-submit" type="submit">
        <span class="submit-label">送出 Send Message</span>
      </button>

      <div class="form-status" id="form-status" role="status" aria-live="polite"></div>
    </form>
  </div>

  <div class="footer-meta">
    <img class="footer-logo" src="/logo/studio-white.png" alt="原本那間剪輯工作室 LTH Film Studio" loading="lazy" />
    <a class="footer-imdb" href="https://www.imdb.com/name/nm6202567/" target="_blank" rel="noopener">IMDb</a>
  </div>

  <div class="footer-bottom">
    <div>© 2026 Tzushien Lin — All rights reserved</div>
    <div>Site designed with care for moving image.</div>
  </div>
</footer>

<script>
  // Filter chips 切換：點 chip → grid 的 data-active-filter 換值
  const chips = document.querySelectorAll<HTMLButtonElement>('.filter-chips .chip');
  const grid = document.querySelector<HTMLDivElement>('.works-grid');

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      const filter = chip.dataset.filter;
      if (!filter || !grid) return;
      chips.forEach((c) => {
        c.classList.toggle('active', c === chip);
        c.setAttribute('aria-selected', c === chip ? 'true' : 'false');
      });
      grid.dataset.activeFilter = filter;
    });
  });

  // === Contact form → Google Forms ===
  const FORM_URL = 'https://docs.google.com/forms/d/e/1FAIpQLScLaazgZxKCSjlsWcTKhqQvMjO2yqr1_dadGpLVAeHINOiBmg/formResponse';
  const FIELDS = {
    name: 'entry.688686802',
    company: 'entry.404711621',
    email: 'entry.2041773789',
    message: 'entry.1443719334',
  } as const;

  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('form-status');

  if (form && status) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const name = String(fd.get('name') || '').trim();
      const email = String(fd.get('email') || '').trim();
      const company = String(fd.get('company') || '').trim();
      const message = String(fd.get('message') || '').trim();

      if (!name || !email || !message) {
        status.textContent = '請填妥姓名、Email、跟訊息內容。';
        status.dataset.kind = 'err';
        return;
      }
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        status.textContent = 'Email 格式好像不太對，再確認一下？';
        status.dataset.kind = 'err';
        return;
      }

      const submitBtn = form.querySelector('.form-submit') as HTMLButtonElement | null;
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.querySelector('.submit-label')!.textContent = '送出中...';
      }
      status.textContent = '';
      status.dataset.kind = '';

      try {
        const body = new URLSearchParams();
        body.append(FIELDS.name, name);
        body.append(FIELDS.company, company);
        body.append(FIELDS.email, email);
        body.append(FIELDS.message, message);
        // Google Forms requires no-cors POST; we never see the actual response
        await fetch(FORM_URL, {
          method: 'POST',
          mode: 'no-cors',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: body.toString(),
        });
        // 因為是 no-cors，永遠 resolve，假設成功
        form.reset();
        status.innerHTML = '✓ 訊息已送出，Nalin 會盡快回覆你。<br/><span style="font-size: 0.78em; opacity: 0.7;">Thanks — your message is on its way.</span>';
        status.dataset.kind = 'ok';
      } catch (err) {
        status.textContent = '送出失敗，請稍後再試或直接寄信到 lthfilmstudio@gmail.com';
        status.dataset.kind = 'err';
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.querySelector('.submit-label')!.textContent = '送出 Send Message';
        }
      }
    });
  }
</script>

</BaseLayout>
