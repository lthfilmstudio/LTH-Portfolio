---
import BaseLayout from '../layouts/BaseLayout.astro';
import BrandMark from '../components/BrandMark.astro';
import WorkCard from '../components/WorkCard.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { works, CATEGORY_LABELS, CATEGORY_ORDER } from '../data/works';
import awards from '../data/awards.json';
import selectedSlugs from '../data/selected.json';
import profile from '../data/profile.json';

// 由 workSlug 對到 works.json 的 cover；沒設或找不到時 fallback 到 a.poster
const worksCoverBySlug = new Map(works.map((w: any) => [w.slug, w.cover]));
const worksBySlug = new Map(works.map((w: any) => [w.slug, w]));
function resolveAwardPoster(a: any): string {
  if (a.workSlug && worksCoverBySlug.has(a.workSlug)) {
    return worksCoverBySlug.get(a.workSlug) || a.poster || '';
  }
  return a.poster || '';
}
function resolveAwardHref(a: any): string | null {
  if (!a.workSlug) return null;
  const w = worksBySlug.get(a.workSlug);
  if (w && w.hasDetail) return `/works/${a.workSlug}/`;
  return null;
}

// Schema.org Person — 讓 Google 搜尋結果顯示獎項、職稱
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: '林姿嫺',
  alternateName: 'Tzushien Lin',
  jobTitle: '剪輯指導 Supervising Editor',
  description: '電影／劇集剪輯指導，兩度金鐘獎最佳剪輯得主',
  url: 'https://lthfilmstudio.com',
  sameAs: ['https://www.imdb.com/name/nm6202567/'],
  worksFor: {
    '@type': 'Organization',
    name: '原本那間剪輯工作室 LTH Film Studio',
    url: 'https://lthfilmstudio.com',
  },
  award: [
    '第 57 屆金鐘獎戲劇類剪輯獎（茶金 Gold Leaf, 2022）',
    '第 45 屆金鐘獎剪輯獎（牽紙鷂的手 The Kite Soaring, 2010）',
    '第 59 屆金鐘獎戲劇類剪輯獎入圍（有生之年 Living, 2024）',
  ],
  knowsLanguage: ['zh-TW', 'nan-TW', 'en', 'hak-TW', 'th'],
};

// Nalin 精選代表作 — 來源 src/data/selected.json，由 /admin/selected 後台維護
const selectedWorks = (selectedSlugs as string[])
  .map((s) => works.find((w) => w.slug === s))
  .filter((w): w is NonNullable<typeof w> => Boolean(w));

function thumbClass(slug: string): string {
  const n = (slug.split('').reduce((a, c) => a + c.charCodeAt(0), 0) % 15) + 1;
  return `th-${n}`;
}
---
<BaseLayout schemaJsonLd={personSchema}>

<div class="bokeh-bg"></div>

<!-- NAV -->
<nav>
  <div class="brand">
    <BrandMark />
    <div class="brand-text">
      <span class="brand-zh">林姿嫺</span>
      <span class="brand-en"><span class="brand-en-name">Tzushien Lin</span><span class="brand-en-role"> · Film & Series Editor</span></span>
    </div>
  </div>
  <ul>
    <li><a href="#works">Works</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
</nav>

<main>

<!-- HERO -->
<section class="hero">
  <div class="hero-left">
    <div class="hero-name-row">
      <h1>{profile.nameZh}</h1>
      <span class="en-name">{profile.nameEn}</span>
    </div>

    <div class="hero-titles">
      <span class="role-zh">{profile.roleZh}</span>
      <span class="role-en">{profile.roleEn}</span>
    </div>

    <div class="hero-profile">
      <p class="lead-zh">{profile.leadZh}</p>
      <p class="lead-en">{profile.leadEn}</p>
      <p class="sub-zh">{profile.subZh}</p>
      <p class="sub-en">{profile.subEn}</p>
    </div>

    {profile.languages && profile.languages.length > 0 && (
      <div class="hero-languages">
        <span class="hero-languages-label">Languages</span>
        <ul class="hero-languages-list">
          {profile.languages.map((l: any) => (
            <li><span class="lang-level">{l.level}</span><span class="lang-name">{l.name}</span></li>
          ))}
        </ul>
      </div>
    )}
  </div>

  <aside class="hero-right">
    <div class="hero-awards-label">
      <span>Awards & Recognition</span>
    </div>

    <div class="hero-awards-row">
      {awards.map((a: any) => {
        const href = resolveAwardHref(a);
        const Tag = href ? 'a' : 'div';
        return (
          <Tag class={`hero-award-item ${a.status}${href ? ' is-linked' : ''}`} {...(href ? { href } : {})}>
            <div class="award-bg" aria-hidden="true">
              <img
                src={resolveAwardPoster(a)}
                alt=""
                loading="lazy"
                style={`object-position: ${a.posterX ?? 50}% ${a.posterY ?? 50}%; transform: scale(${(a.posterScale ?? 100) / 100});`}
              />
            </div>
            <div class="award-content">
              <div class="award-meta">
                <span class="award-status-sm"><span class="dot"></span> {a.statusZh} · {a.statusEn}</span>
                <span class="award-yr">{a.year}</span>
              </div>
              <div class="award-work">{a.workZh}<span class="work-en">{a.workEn}</span></div>
              <div class="award-name-sm">
                <span class="award-name-zh">{a.awardZh}</span>
                <span class="award-name-en">{a.awardEn}</span>
              </div>
            </div>
          </Tag>
        );
      })}
    </div>
  </aside>

  <div class="featured-label">
    <span>Selected Works</span>
  </div>

  <div class="featured-list-wrap">
    <button class="featured-scroll-cue featured-scroll-cue--left" type="button" aria-label="向左捲動">
      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M19 12H5M12 5l-7 7 7 7" />
      </svg>
    </button>
    <div class="featured-list" id="featured-list">
      {selectedWorks.map((w, i) => (
        <a class="featured-item" href={w.hasDetail ? `/works/${w.slug}/` : '#'}>
          <span class="featured-num" aria-hidden="true">{i + 1}</span>
          {w.cover ? (
            <div class="featured-thumb featured-thumb--image">
              <img src={w.cover} alt={`${w.titleZh} ${w.titleEn}`.trim()} loading="lazy" />
            </div>
          ) : (
            <div class={`thumb featured-thumb ${thumbClass(w.slug)}`} data-short={w.titleZh.slice(0, 4)}></div>
          )}
          <span class="title">
            <span class="title-zh">{w.titleZh}</span>
            {w.titleEn && <span class="title-en">{w.titleEn}</span>}
          </span>
        </a>
      ))}
    </div>
    <button class="featured-scroll-cue featured-scroll-cue--right" type="button" aria-label="向右捲動">
      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M5 12h14M12 5l7 7-7 7" />
      </svg>
    </button>
  </div>

  <a class="scroll-cue" href="#works" aria-label="往下看作品集">
    <span class="scroll-cue-label">作品集 Portfolio</span>
    <span class="scroll-cue-arrow" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M12 5v14M5 12l7 7 7-7" />
      </svg>
    </span>
  </a>
</section>

<script>
  // Selected Works 左右捲動箭頭：一次 5 個，用瀏覽器原生 smooth scroll（GPU 加速）
  document.addEventListener('DOMContentLoaded', () => {
    const list = document.getElementById('featured-list');
    const cueLeft = document.querySelector('.featured-scroll-cue--left');
    const cueRight = document.querySelector('.featured-scroll-cue--right');
    if (!list || !cueLeft || !cueRight) return;

    const ITEMS_PER_PAGE = 5;

    function getItems(): HTMLElement[] {
      return Array.from(list.querySelectorAll<HTMLElement>('.featured-item'));
    }

    // 找目前最左邊那張可見的 item index
    function firstVisibleIdx(): number {
      const items = getItems();
      const sl = list.scrollLeft;
      for (let i = 0; i < items.length; i++) {
        if (items[i].offsetLeft >= sl - 4) return i;
      }
      return Math.max(0, items.length - 1);
    }

    // 動畫進行中，用 pendingTarget 取代真實 scrollLeft 來算 cue 顯示
    let pendingTarget: number | null = null;
    let pendingTimer = 0;

    function doScroll(target: number) {
      pendingTarget = target;
      list.scrollTo({ left: target, behavior: 'smooth' });
      window.clearTimeout(pendingTimer);
      pendingTimer = window.setTimeout(() => {
        pendingTarget = null;
        updateCues();
      }, 900);
      updateCues();
    }

    // 滾到指定 item 為左邊；若是最後一頁就 snap 到 maxScroll
    function scrollToIdx(idx: number) {
      const items = getItems();
      if (!items.length) return;
      const maxScroll = Math.max(0, list.scrollWidth - list.clientWidth);
      if (idx <= 0) { doScroll(0); return; }
      if (idx + ITEMS_PER_PAGE - 1 >= items.length - 1) {
        doScroll(maxScroll);
        return;
      }
      idx = Math.min(items.length - 1, idx);
      let target = items[idx].offsetLeft;
      if (target > maxScroll) target = maxScroll;
      doScroll(target);
    }

    const updateCues = () => {
      const overflow = list.scrollWidth - list.clientWidth;
      if (overflow <= 8) {
        cueLeft.setAttribute('hidden', '');
        cueRight.setAttribute('hidden', '');
        return;
      }
      // 動畫中以 target 為準，避免中途位置造成箭頭閃現
      const effectiveLeft = pendingTarget !== null ? pendingTarget : list.scrollLeft;
      cueLeft.toggleAttribute('hidden', effectiveLeft <= 8);
      const remaining = overflow - effectiveLeft;
      cueRight.toggleAttribute('hidden', remaining <= 8);
    };

    cueLeft.addEventListener('click', () => {
      scrollToIdx(firstVisibleIdx() - ITEMS_PER_PAGE);
    });
    cueRight.addEventListener('click', () => {
      scrollToIdx(firstVisibleIdx() + ITEMS_PER_PAGE);
    });
    list.addEventListener('scroll', updateCues, { passive: true });
    window.addEventListener('resize', updateCues);
    updateCues();
  });
</script>

<!-- PORTFOLIO SECTION DIVIDER -->
<div class="section-divider" id="works">
  <span class="num">01 / Portfolio</span>
  <div class="line"></div>
  <h2>作品 <span class="en">Portfolio</span></h2>
</div>

<!-- PORTFOLIO -->
<section class="portfolio">
  <div class="filter-chips" role="tablist">
    {CATEGORY_ORDER.map((cat, idx) => {
      const count = works.filter((w) => w.categories.includes(cat)).length;
      if (count === 0) return null;
      const isDefault = cat === 'feature';
      return (
        <>
          <button
            class={`chip${isDefault ? ' active' : ''}`}
            data-filter={cat}
            type="button"
            role="tab"
            aria-selected={isDefault ? 'true' : 'false'}
          >
            {CATEGORY_LABELS[cat].zh} <span class="chip-en">{CATEGORY_LABELS[cat].en}</span>
          </button>
          {idx === 3 && <div class="chip-break" aria-hidden="true"></div>}
        </>
      );
    })}
  </div>

  <div class="works-grid" data-active-filter="feature">
    {works.map((work) => (
      <WorkCard work={work} />
    ))}
  </div>
</section>

</main>

<!-- FOOTER -->
<SiteFooter />

<script>
  // Filter chips 切換：點 chip → grid 的 data-active-filter 換值
  const chips = document.querySelectorAll<HTMLButtonElement>('.filter-chips .chip');
  const grid = document.querySelector<HTMLDivElement>('.works-grid');

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      const filter = chip.dataset.filter;
      if (!filter || !grid) return;
      chips.forEach((c) => {
        c.classList.toggle('active', c === chip);
        c.setAttribute('aria-selected', c === chip ? 'true' : 'false');
      });
      grid.dataset.activeFilter = filter;
    });
  });

</script>

</BaseLayout>
